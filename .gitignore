# ── Secrets ───────────────────────────────────────────────────────────────────
# Root .env has DB credentials — never commit it
/.env
.env.server
.deploy.env
# React local overrides (react-app/.env and .env.production are safe to commit)
react-app/.env.local
react-app/.env.*.local

# ── React ─────────────────────────────────────────────────────────────────────
react-app/node_modules/
react-app/dist/
# frontend/ is the build output — tracked in git, deployed via git pull

# ── CodeIgniter ───────────────────────────────────────────────────────────────
application/logs/*.php
application/cache/*
.migrated

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
