# Copy this to .env and fill in real values — NEVER commit .env to git

# ── Environment ───────────────────────────────────────────────────────────────
# Use 'production' on the live server (disables error display & DB debug)
CI_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# cPanel → MySQL Databases to find these values
DB_HOST=localhost
DB_USER=cpanelusername_dbuser
DB_PASSWORD=your_db_password
DB_NAME=cpanelusername_tnpsc_prep

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string — openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_secret

# ── Base URL (usually leave blank) ───────────────────────────────────────────
# config.php auto-detects from HTTP_HOST. Only set if behind a reverse proxy.
# APP_BASE_URL=https://yourdomain.com/edu/
